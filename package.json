{
  "name": "furlong",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@9.12.0",
  "engines": { "node": ">=20" },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @furlong/db generate",
    "db:migrate": "pnpm --filter @furlong/db migrate",
    "db:studio": "pnpm --filter @furlong/db studio",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "ml:dev": "cd services/ml && uvicorn app.main:app --reload --port 8000"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  }
}
