# ---- Postgres ----
# Host port 5433 (see docker-compose.yml) to avoid clashing with other
# local Postgres containers bound to 5432.
DATABASE_URL="postgresql://furlong:furlong@localhost:5433/furlong?schema=public"

# ---- Redis (job queue + cache) ----
REDIS_URL="redis://localhost:6380"

# ---- API ----
# 4100 to avoid clashing with other local dev servers on 4000.
API_PORT=4100

# ---- ML service ----
ML_SERVICE_URL="http://localhost:8000"

# ---- Web ----
NEXT_PUBLIC_API_URL="http://localhost:4100"

# ---- Auth (Phase 4) ----
# Secret for signing session tokens (JWT HS256). REQUIRED in production.
AUTH_SECRET="change-me-to-a-long-random-string"

# ---- Alert delivery (Phase 4). Unset => alerts log to console (dev). ----
# Email via Resend (https://resend.com)
RESEND_API_KEY=""
ALERT_FROM_EMAIL="Furlong <alerts@yourdomain.com>"
# SMS via Twilio
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# ---- Automation / scheduled jobs (Phase 2d). OFF by default. ----
# Boot the BullMQ worker + repeatable schedules (run: pnpm --filter @furlong/api worker).
JOBS_ENABLED="false"
# Permit the discovery/ingest jobs to reach out to auction-house sources.
# ROADMAP invariant: production should point these at a LICENSED feed, not scrape.
DISCOVERY_ENABLED="false"
# Token guarding the manual POST /jobs/run/:name triggers. Unset => endpoints disabled.
JOBS_ADMIN_TOKEN=""
# Cron schedules (override if desired).
CRON_DISCOVER="0 6 * * *"
CRON_SALE_SOON="0 * * * *"
CRON_RETRAIN="0 3 * * 0"
# Fire SALE_SOON alerts when a sale starts within this many hours.
SALE_SOON_WINDOW_HOURS=48

# ---- Optional: LLM for plain-English valuation summaries only ----
# Structured numeric prediction is deterministic in the ML service.
ANTHROPIC_API_KEY=""
