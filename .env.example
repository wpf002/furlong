# ---- Postgres ----
# Host port 5433 (see docker-compose.yml) to avoid clashing with other
# local Postgres containers bound to 5432.
DATABASE_URL="postgresql://furlong:furlong@localhost:5433/furlong?schema=public"

# ---- Redis (job queue + cache) ----
REDIS_URL="redis://localhost:6380"

# ---- API ----
# 4100 to avoid clashing with other local dev servers on 4000.
API_PORT=4100

# ---- ML service ----
ML_SERVICE_URL="http://localhost:8000"

# ---- Web ----
NEXT_PUBLIC_API_URL="http://localhost:4100"

# ---- Optional: LLM for plain-English valuation summaries only ----
# Structured numeric prediction is deterministic in the ML service.
ANTHROPIC_API_KEY=""
