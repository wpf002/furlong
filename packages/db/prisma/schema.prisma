// Furlong data model.
// Invariant: all money stored as integer cents (BigInt). Never floats for money.
// Pedigree is modeled via self-referential Horse relations (sire / dam).
// Damsire is derived through dam.sire — not stored separately.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Connection URL lives in prisma.config.ts (Prisma 7); the runtime client
  // connects via the @prisma/adapter-pg driver adapter.
}

enum Sex {
  COLT
  FILLY
  GELDING
  MARE
  STALLION
}

enum AuctionHouse {
  KEENELAND
  FASIG_TIPTON
  TATTERSALLS
  GOFFS
  OBS
  INGLIS
}

model Horse {
  id             String  @id @default(cuid())
  name           String?
  normalizedName String? // entity-resolution match key (see normalizeEntityName)
  sex            Sex?
  color          String?
  foalingYear    Int?

  // Racing record (Phase 4, horses-in-training). NULL until a licensed feed
  // (Equibase US / Timeform UK-IRE) populates them — the ROADMAP gates real
  // racing-performance data behind a license, so these stay empty in dev and the
  // racing-age valuation degrades to pedigree comparables when absent.
  starts          Int?
  wins            Int?
  places          Int? // 2nd-place finishes
  shows           Int? // 3rd-place finishes
  earningsCents   BigInt? // career earnings, minor units of the horse's home currency
  bestSpeedFigure Int? // best speed/class figure (Beyer / Timeform), license-pending
  racingUpdatedAt DateTime?

  // self-referential pedigree
  sireId String?
  sire   Horse?  @relation("Sire", fields: [sireId], references: [id])
  damId  String?
  dam    Horse?  @relation("Dam", fields: [damId], references: [id])

  sireOf    Horse[]     @relation("Sire")
  damOf     Horse[]     @relation("Dam")
  hips      Hip[]
  sireStats SireStats[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([normalizedName])
  @@index([sireId])
  @@index([damId])
}

model Consignor {
  id             String   @id @default(cuid())
  name           String   @unique
  normalizedName String   @unique // entity-resolution match key
  hips           Hip[]
  createdAt      DateTime @default(now())
}

model Breeder {
  id             String   @id @default(cuid())
  name           String   @unique
  normalizedName String   @unique // entity-resolution match key
  hips           Hip[]
  createdAt      DateTime @default(now())
}

enum SaleCategory {
  YEARLING
  BREEDING_STOCK
  TWO_YEAR_OLD
  WEANLING
  MIXED
  OTHER
}

model Sale {
  id           String       @id @default(cuid())
  auctionHouse AuctionHouse
  name         String
  year         Int
  startDate    DateTime?
  endDate      DateTime?
  currency     String       @default("USD") // ISO 4217; money stored in minor units of this
  category     SaleCategory @default(YEARLING)
  hips         Hip[]
  createdAt    DateTime     @default(now())

  @@unique([auctionHouse, name, year])
}

model Hip {
  id            String  @id @default(cuid())
  saleId        String
  sale          Sale    @relation(fields: [saleId], references: [id])
  hipNumber     Int
  sessionNumber Int?

  // Under-tack ("breeze") work for 2YO-in-training sales (e.g. OBS). breezeTime
  // is the raw published time for display (e.g. ":10 1/5"); breezeSeconds is
  // normalized to seconds-per-furlong (lower = faster) so works at 1/8 vs 1/4
  // mile are comparable and usable as a valuation signal. NULL for non-2YO sales.
  breezeTime    String?
  breezeSeconds Float?

  horseId String
  horse   Horse  @relation(fields: [horseId], references: [id])

  consignorId String?
  consignor   Consignor? @relation(fields: [consignorId], references: [id])
  breederId   String?
  breeder     Breeder?   @relation(fields: [breederId], references: [id])

  withdrawn  Boolean    @default(false) // pulled from the sale before it rings

  result     SaleResult?
  valuations Valuation[]

  createdAt DateTime @default(now())

  @@unique([saleId, hipNumber])
  @@index([horseId])
}

model SaleResult {
  id         String    @id @default(cuid())
  hipId      String    @unique
  hip        Hip       @relation(fields: [hipId], references: [id])
  priceCents BigInt? // null when RNA / not sold
  rna        Boolean   @default(false)
  buyer      String?
  soldAt     DateTime?
  createdAt  DateTime  @default(now())
}

model Valuation {
  id                 String   @id @default(cuid())
  hipId              String
  hip                Hip      @relation(fields: [hipId], references: [id])
  estValueLowCents   BigInt
  estValueHighCents  BigInt
  predPriceLowCents  BigInt
  predPriceHighCents BigInt
  confidence         Float // 0..1
  hiddenGemScore     Float? // (est value mid) - (pred price mid), normalized
  limitedComparables Boolean  @default(false) // thin-data flag; UI never fakes precision
  modelVersion       String
  summary            String? // plain-English rationale
  features           Json?
  createdAt          DateTime @default(now())

  @@index([hipId])
  @@index([modelVersion])
}

model SireStats {
  id                 String   @id @default(cuid())
  sireId             String
  sire               Horse    @relation(fields: [sireId], references: [id])
  year               Int
  avgYearlingCents   BigInt?
  earningsPerStarter BigInt?
  stakesWinnerPct    Float?
  studFeeCents       BigInt?
  createdAt          DateTime @default(now())

  @@unique([sireId, year])
}

model User {
  id          String         @id @default(cuid())
  email       String         @unique
  phone       String? // E.164 for SMS alerts
  notifyEmail Boolean        @default(true)
  notifySms   Boolean        @default(false)
  createdAt   DateTime       @default(now())
  profiles    BuyerProfile[]
  shortlists  Shortlist[]
  alerts      Alert[]
}

enum AlertType {
  CATALOG_DROP
  CRITERIA_MATCH
  SALE_SOON
}

model Alert {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  type      AlertType
  saleId    String? // soft link to a Sale (no FK; sales may predate the alert)
  title     String
  body      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, createdAt])
}

model BuyerProfile {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  budgetLowCents  BigInt?
  budgetHighCents BigInt?
  preferredSires  String[]
  notes           String?
  createdAt       DateTime @default(now())
}

model Shortlist {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id])
  name      String
  items     ShortlistItem[]
  createdAt DateTime        @default(now())
}

model ShortlistItem {
  id          String    @id @default(cuid())
  shortlistId String
  shortlist   Shortlist @relation(fields: [shortlistId], references: [id])
  hipId       String
  note        String?
  createdAt   DateTime  @default(now())

  @@unique([shortlistId, hipId])
}
