{
  "$schema": "https://schema.up.railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm --filter @furlong/db exec prisma generate"
  },
  "deploy": {
    "startCommand": "pnpm --filter @furlong/api exec tsx src/jobs/worker.ts",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
